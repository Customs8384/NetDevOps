# 1) Confirm init and runit processes
ps -p 1 -o comm=
pgrep -a runsvdir || pgrep -a runsv || true

# 2) Create the service link (safe, idempotent)
sudo ln -sf /etc/sv/spice-vdagentd /etc/service/spice-vdagentd

# 3) Ask sv to bring the service up
sudo sv up spice-vdagentd || sudo sv restart spice-vdagentd

# 4) If sv/runsvdir are not present or not running, start runsvdir supervising /etc/service
# Only run this if your distro expects runsvdir to be started manually
